PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# MVP auth. Use this for deployment smoke tests before login/JWT exists.
PROJECT_TOKEN="replace-with-a-long-random-secret"

# Optional production auth. When set, signed JWTs with a projectId claim are also accepted.
# JWT_SECRET="replace-with-a-long-random-secret"

# Optional comma-separated CORS origins. Use * or leave empty for local development.
# CORS_ORIGIN=http://localhost:3000,http://localhost:6006
